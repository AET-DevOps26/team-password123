# GenAI Service Configuration
# 
# IMPORTANT: If using LLM_PROVIDER=ollama, you MUST have Ollama installed and running locally
# Install from https://ollama.ai and run: ollama pull llava
#
# LLM Provider: "ollama" (local, offline) or "openai" (cloud)
LLM_PROVIDER=ollama

# Ollama settings (used if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava

# OpenAI settings (used if LLM_PROVIDER=openai or as fallback)
# OPENAI_API_KEY=sk-...

# GenAI service port and debug mode
PORT=8084
DEBUG=true
